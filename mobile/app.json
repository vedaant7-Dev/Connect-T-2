{
  "expo": {
    "name": "Connect T",
    "slug": "connect-t-final-2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "connectt",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EA580C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.connectt.app"
    },
    "android": {
      "package": "com.connectt.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#EA580C"
      },
      "permissions": [

        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "ACCESS_FINE_LOCATION",
        "VIBRATE"
      ],
      "abiFilters": [
        "armeabi-v7a",
        "arm64-v8a"

        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.VIBRATE"
 a10de85 (Update app permissions and package name for Android builds)
      ]
    },
    "androidStatusBar": {
      "barStyle": "light-content",
      "backgroundColor": "#EA580C",
      "translucent": false
    },
    "androidNavigationBar": {
      "visible": "sticky-immersive",
      "barStyle": "light-content",
      "backgroundColor": "#EA580C"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1dbe66ec-03ef-4507-b632-399a0d1e1bfd"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/1dbe66ec-03ef-4507-b632-399a0d1e1bfd",
      "runtimeVersion": {
        "policy": "appVersion"
      },
      "checkAutomatically": "ON_LOAD"
    },
    "owner": "vedantt7"
  }
}
