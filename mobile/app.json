{
  "expo": {
    "name": "Connect T",
    "slug": "connect-t-final-2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "connectt",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.connectt.app"
    },
    "android": {
      "package": "com.connectt.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#EA580C"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.VIBRATE"
      ],
      "softwareKeyboardLayoutMode": "resize"
    },
    "androidStatusBar": {
      "barStyle": "light-content",
      "backgroundColor": "#EA580C",
      "translucent": false
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-image",
      "expo-status-bar",
      "expo-build-properties",
      "./plugins/withAndroidAbiSplits"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1dbe66ec-03ef-4507-b632-399a0d1e1bfd"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/1dbe66ec-03ef-4507-b632-399a0d1e1bfd",
      "checkAutomatically": "ON_LOAD"
    },
    "owner": "vedantt7",
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
