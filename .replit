modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Connect-T Mobile"

[[workflows.workflow]]
name = "Connect-T Mobile"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd mobile && npm install --no-audit --no-fund && npx expo start --web --host 0.0.0.0 --port 8081"
waitForPort = 8081

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 3003

[[ports]]
localPort = 3306
externalPort = 5173

[[ports]]
localPort = 5000
externalPort = 6800

[[ports]]
localPort = 5001
externalPort = 8000

[[ports]]
localPort = 5173
externalPort = 8008

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80
exposeLocalhost = true

[[ports]]
localPort = 8082
externalPort = 6000

[[ports]]
localPort = 8083
externalPort = 3001

[[ports]]
localPort = 8084
externalPort = 4200

[[ports]]
localPort = 8085
externalPort = 5000

[[ports]]
localPort = 24866
externalPort = 3000

[[ports]]
localPort = 24867
externalPort = 3002

[nix]
channel = "stable-25_05"
packages = ["nano", "fltk14", "eas-cli", "zulu"]
